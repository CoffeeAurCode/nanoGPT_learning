# ─────────────────────────────────────────────────────────────────────────────
# nanoGPT environment variables
# Copy this file to .env and fill in your values.
# nanoGPT does not load .env automatically — export these in your shell or
# use a tool like python-dotenv if you add it to your workflow.
# ─────────────────────────────────────────────────────────────────────────────

# Weights & Biases API key — only required if you set wandb_log=True in a config
# Obtain yours at: https://wandb.ai/authorize
# WANDB_API_KEY=your_key_here

# ─── Distributed training (set automatically by torchrun — do not set manually) ─
# RANK=0
# LOCAL_RANK=0
# WORLD_SIZE=1

# ─── Test suite ──────────────────────────────────────────────────────────────
# Set INTEGRATION=1 to run integration tests that require network access
# or a CUDA GPU (e.g., downloading GPT-2 weights from HuggingFace).
# INTEGRATION=1

# ─── HuggingFace cache (optional) ────────────────────────────────────────────
# Override where HuggingFace stores downloaded models and datasets.
# Useful if your home directory is on a small partition.
# HF_HOME=/path/to/large/disk/.cache/huggingface
